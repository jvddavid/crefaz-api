{
  "name": "@jvddavid/crefaz-api",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "description": "An API for Crefaz, a Brazilian credit bureau. This API provides access to credit reports, scores, and other related information.",
  "private": false,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "keywords": [
    "crefaz",
    "api",
    "crefaz-api"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvddavid/crefaz-api.git"
  },
  "bugs": {
    "url": "https://github.com/jvddavid/crefaz-api/issues"
  },
  "homepage": "https://github.com/jvddavid/crefaz-api#readme",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "pkgroll": "^2.27.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "generate:cities": "node scripts/generate-city-constants.mjs",
    "build": "pnpm run generate:cities && pkgroll --clean-dist",
    "prepack": "pnpm run lint && pnpm run typecheck && pnpm run build",
    "start": "node src/index.ts",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "typecheck": "tsc --noEmit",
    "dev": "node --watch src/index.ts",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:homologacao:energia": "pnpm run build && node --test tests/homologacao/energia.ofertas.test.mjs",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "release:patch": "npm run version:patch && git push --follow-tags",
    "release:minor": "npm run version:minor && git push --follow-tags",
    "release:major": "npm run version:major && git push --follow-tags",
    "publish:github": "pnpm publish --registry https://npm.pkg.github.com",
    "login:github": "npm login --registry=https://npm.pkg.github.com"
  },
  "dependencies": {},
  "optionalDependencies": {},
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  }
}
